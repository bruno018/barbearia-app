# Porta do servidor (padrão: 3001)
PORT=3001

# ─────────────────────────────────────────────
# WhatsApp via Z-API (https://z-api.io)
# Preencha após criar sua instância na Z-API
# ─────────────────────────────────────────────
ZAPI_INSTANCE=SUA_INSTANCIA_AQUI
ZAPI_TOKEN=SEU_TOKEN_AQUI

# ─────────────────────────────────────────────
# Alternativa: Twilio WhatsApp
# ─────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─────────────────────────────────────────────
# Modo de envio: 'zapi' | 'twilio' | 'link' (padrão, abre wa.me)
# ─────────────────────────────────────────────
WHATSAPP_MODE=link
